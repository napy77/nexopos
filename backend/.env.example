# Servidor
PORT=4000

# PostgreSQL (instancia dedicada del POS)
DATABASE_URL=postgres://nexopos:nexopos@localhost:5433/nexopos

# JWT emitido por el POS tras validar credenciales contra NexoB2B
JWT_SECRET=cambiar-en-produccion

# Integración NexoB2B (backend Medusa)
# Si NEXOB2B_API_URL está vacío, el POS corre en MODO MOCK:
# catálogo, mayoristas y órdenes simulados; login demo (cualquier email / "demo").
# Para producción:
#   NEXOB2B_API_URL=https://nexob2b.app
#   NEXOB2B_PUBLISHABLE_KEY=pk_...   (Medusa dashboard → Settings → API Keys → Publishable)
NEXOB2B_API_URL=
NEXOB2B_PUBLISHABLE_KEY=
